<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{displayName}} — Resume</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jersey+15&family=Roboto+Mono&family=Sixtyfour&display=swap" rel="stylesheet">
<style>
  /* === Reset === */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* === Base === */
  body {
    font-family: 'Roboto Mono', monospace;
    font-size: 9.5pt;
    line-height: 1.6;
    color: #fff;
    /* Background is now handled by the ::before pseudo-element for a fixed effect */
  }

  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: -1;
    background-color: #40e0d0; /* bright turquoise */
    background-image: url("data:image/svg+xml,%3csvg width='100%25' xmlns='http://www.w3.org/2000/svg'%3e%3cdefs%3e%3cpath id='path1' d='M-5,50 H200 V80 H400 V20 H600 V100 H800 V40 H1000 V120 H1200 V60 H1400 V140 H1600 V80 H1800 V160 H2005' stroke='black' stroke-width='0.5' fill='none'/%3e%3cpath id='path2' d='M2005,200 H1800 V250 H1600 V180 H1400 V280 H1200 V220 H1000 V300 H800 V240 H600 V320 H400 V260 H200 V340 H-5' stroke='black' stroke-width='0.5' fill='none'/%3e%3cpath id='path3' d='M-5,400 H300 L 400 350 H 600 L 700 450 H 900 L 1000 400 H 1200 L 1300 500 H 1500 L 1600 450 H 2005' stroke='black' stroke-width='0.5' fill='none'/%3e%3c/defs%3e%3cuse href='%23path1'/%3e%3cuse href='%23path2'/%3e%3cuse href='%23path3'/%3e%3ccircle r='2' fill='black'%3e%3canimateMotion dur='20s' repeatCount='indefinite'%3e%3cmpath href='%23path1'/%3e%3c/animateMotion%3e%3c/circle%3e%3ccircle r='2' fill='black'%3e%3canimateMotion dur='25s' repeatCount='indefinite'%3e%3cmpath href='%23path2'/%3e%3c/animateMotion%3e%3c/circle%3e%3ccircle r='2' fill='black'%3e%3canimateMotion dur='18s' repeatCount='indefinite'%3e%3cmpath href='%23path3'/%3e%3c/animateMotion%3e%3c/circle%3e%3c/svg%3e");
    background-position: center calc(50% + 160px);
    background-repeat: no-repeat;
  }

  .container {
    background: #000;
    max-width: 8.5in; /* Standard letter paper width */
    min-height: 11in; /* Standard letter paper height */
    margin: 20px auto;
    padding: 40px;
    display: flex;
    gap: 40px;
  }

  h1, h2, h3 {
    color: #ff0; /* yellow */
  }

  h1 {
    font-family: 'Sixtyfour', sans-serif;
    font-size: 44px;
    color: #00ffff; /* cyan */
    text-align: center;
    margin-bottom: 30px;
  }

  h2 {
    font-family: 'Jersey 15', sans-serif;
    font-size: 26px;
    border-bottom: 2px solid #ff0;
    padding-bottom: 5px;
    margin-bottom: 15px;
  position: relative;
  overflow: hidden;
  }

  h3 {
    font-size: 12.5pt;
    margin-bottom: 5px;
  }

  a {
    color: #00ffff;
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }

  /* === Print === */
  @page { size: A4; margin: 15mm 20mm; }
  @media print {
    body { background: #fff; color: #000; }
    .container { background: #fff; box-shadow: none; margin: 0; padding: 0; display: flex; gap: 30px; }
    h1, h2, h3 { color: #000; }
    h1 { color: #000; text-shadow: none; }
    h2 { border-bottom-color: #000; }
    a { color: #000; }
    section { background: transparent; border: none; clip-path: none; padding: 0; margin-bottom: 20px; background-image: none; }
    section::before, section::after { display: none; }
    .hero-image { -webkit-print-color-adjust: exact; color-adjust: exact; border: 2px solid #000; box-shadow: none; animation: none; }
    .pulsing-glow-border, .pulsing-glow-text { animation: none; }
    body::before { display: none; }
    h2::after { display: none; }
  }

  /* === Layout === */
  .left-column {
    flex: 1;
    padding-right: 20px;
    border-right: 1px solid #444;
  }

  .right-column {
    flex: 2;
  }

  section {
    position: relative;
    margin-bottom: 40px;
    padding: 25px;
    background-color: #101010;
    border: 2px solid #555;
    clip-path: polygon(0 15px, 15px 0, calc(100% - 20px) 2px, 100% 22px, 98% calc(100% - 10px), calc(100% - 12px) 100%, 20px calc(100% - 5px), 2px 90%);
    /* Circuit patterns */
    background-image:
      url("data:image/svg+xml,%3csvg width='50' height='50' xmlns='http://www.w3.org/2000/svg'%3e%3cpath d='M10 2 L30 2 L30 20 L48 20' fill='none' stroke='%23888' stroke-width='1.5'/%3e%3cpath d='M30 2 L48 12' fill='none' stroke='%23888' stroke-width='1'/%3e%3ccircle cx='10' cy='2' r='2' fill='%23888'/%3e%3ccircle cx='48' cy='20' r='2' fill='%23888'/%3e%3ccircle cx='48' cy='12' r='2' fill='%23888'/%3e%3c/svg%3e"),
      url("data:image/svg+xml,%3csvg width='50' height='50' xmlns='http://www.w3.org/2000/svg'%3e%3cpath d='M40 48 L20 48 L20 30 L2 30' fill='none' stroke='%23888' stroke-width='1.5'/%3e%3cpath d='M20 48 L2 38' fill='none' stroke='%23888' stroke-width='1'/%3e%3ccircle cx='40' cy='48' r='2' fill='%23888'/%3e%3ccircle cx='2' cy='30' r='2' fill='%23888'/%3e%3ccircle cx='2' cy='38' r='2' fill='%23888'/%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-size: 50px, 50px;
    background-position: top right, bottom left;
  }

  section::before,
  section::after {
    content: "";
    position: absolute;
    background-color: #888; /* light grey */
  }

  section::before {
    width: 3px;
    height: 50px;
    top: -10px;
    left: 30%;
    transform: rotate(45deg);
  }

  section::after {
    width: 60px;
    height: 4px;
    bottom: 30%;
    right: -12px;
    transform: rotate(25deg);
  }

  h2::after {
    content: '';
    position: absolute;
    bottom: calc(-3.1px - 0.1em);
    left: 0;
    width: 6px;
    height: 6px;
    background-color: #ff0;
    border-radius: 50%;
    box-shadow: 0 0 5px #ff0, 0 0 8px #ff0;
    animation: move-dot 4s linear infinite;
  }

  /* === Glow Effect === */
  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 3px #00ffff, 0 0 8px #00ffff, 0 0 10px #00ffff;
      text-shadow: 0 0 2px #00ffff, 0 0 5px #00ffff;
    }
    50% {
      box-shadow: 0 0 8px #00ffff, 0 0 15px #00ffff, 0 0 25px #00ffff;
      text-shadow: 0 0 5px #00ffff, 0 0 10px #00ffff;
    }
  }

  .pulsing-glow-text {
    animation: pulse-glow 3s ease-in-out infinite;
  }

  .hero-image {
    width: 118px;
    height: 118px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 25px;
    display: block;
    border: 3px solid #00ffff;
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes move-dot {
    from {
      left: -5px;
    }
    to {
      left: 100%;
    }
  }

  .pre-header-text {
    font-family: 'Roboto Mono', monospace;
    color: #00ffff; /* cyan */
    text-align: center;
    margin-bottom: 15px;
    font-size: 11pt;
    letter-spacing: 0.1em;
    font-weight: bold;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .social-icon {
    width: 1.1em;
    height: 1.1em;
    fill: #00ffff; /* cyan */
    flex-shrink: 0;
  }

  /* === Components === */
  .contact-info {
    margin-top: 5px;
  }

  .contact-info p {
    margin-bottom: 10px;
  }

  .skills-list .skill-category {
    margin-bottom: 15px;
  }
  .skills-list strong {
    color: #ff0;
    display: block;
    margin-bottom: 8px;
  }
  .skill-tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .skill-tag {
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 8.5pt;
    color: #000;
    font-weight: bold;
  }
  .skill-tag:nth-child(4n+1) { background-color: #ff0; } /* yellow */
  .skill-tag:nth-child(4n+2) { background-color: #00ffff; } /* cyan */
  .skill-tag:nth-child(4n+3) { background-color: #ff00ff; } /* pink */
  .skill-tag:nth-child(4n+4) { background-color: #9d00ff; } /* purple */

  .language-tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .language-tag {
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 8.5pt;
    color: #000;
    font-weight: bold;
  }
  .language-tag .proficiency {
    font-weight: normal;
    opacity: 0.8;
  }
  .lang-english { background-color: #00ff00; } /* bright green */
  .lang-spanish { background-color: #ffa500; } /* orange */
  .lang-japanese { background-color: #ff0; } /* yellow */

  .experience-item, .education-item {
    margin-bottom: 20px;
  }
  .experience-item p, .education-item p {
    margin-bottom: 5px;
  }
  .experience-item ul {
    list-style-position: inside;
    padding-left: 5px;
  }
  .experience-item .company-name {
    color: #00ffff; /* cyan */
  }
  .item .organization-name {
    color: #00ffff; /* cyan */
  }

  .item {
    margin-bottom: 20px;
  }
  .item:last-child {
    margin-bottom: 0;
  }
  .item p {
    margin-bottom: 5px;
  }

  .testimonial-item {
    margin-bottom: 20px;
  }
  .testimonial-item blockquote {
    border-left: 2px solid #00ffff;
    padding-left: 15px;
    margin: 0 0 10px 5px;
    font-style: italic;
    color: #ccc;
  }
  .testimonial-item cite {
    display: block;
    text-align: right;
  }

  .experience-item li {
    margin-bottom: 5px;
  }

  footer {
    text-align: center;
    padding-top: 20px;
    margin-top: auto; /* Pushes footer to bottom if content is short */
    font-size: 8.5pt;
    color: #888;
    width: 100%;
  }
  footer a {
    color: #aaa;
  }

</style>
</head>
<body>

<div class="container">
  <aside class="left-column">
    <p class="pre-header-text">SENIOR FULL STACK DEVELOPER</p>
    {{#if photo}}
    <img src="{{photo}}" alt="{{displayName}}" class="hero-image" />
    {{/if}}

    <h1 class="pulsing-glow-text">{{displayName}}</h1>
    {{#title}}<p style="text-align: center; margin-top: -15px; margin-bottom: 20px;">{{title}}</p>{{/title}}

    <section class="contact-info">
      <h2>Contact</h2>
      {{#email}}<p><a href="mailto:{{email}}">{{email}}</a></p>{{/email}}
      {{#phone}}<p>{{phone}}</p>{{/phone}}
      {{#website}}<p><a href="{{website}}">{{stripProtocol website}}</a></p>{{/website}}
      {{#locationStr}}<p>{{locationStr}}</p>{{/locationStr}}
      {{#has socialLinks}}
        {{#socialLinks}}
          <p>
            <a href="{{url}}" class="social-link">
              {{#if (eq key "github")}}
              <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21-.15.46-.55.38A8.013 8.013 0 0 1 8 0Z"></path></svg>
              {{else if (eq key "linkedin")}}
              <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2ZM8 19H5V8h3v11ZM6.5 6.73c-.97 0-1.75-.79-1.75-1.76s.78-1.76 1.75-1.76 1.75.79 1.75 1.76-.78 1.76-1.75 1.76ZM19 19h-3v-5.34c0-1.27-.03-2.9-1.76-2.9-1.76 0-2.04 1.37-2.04 2.8v5.44H9V8h2.88v1.32h.04c.42-.79 1.44-1.62 2.84-1.62 3.03 0 3.59 1.99 3.59 4.58V19Z"></path></svg>
              {{else if (eq key "twitter")}}
              <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M9.237 6.522 14.634 0H13.21l-4.573 5.46-3.65-5.46H0l5.683 8.4-5.683 7.6h1.424l4.92-5.873 3.88 5.873h4.92L9.237 6.522Zm-1.12 1.26L7.26 6.66l-4.55-6.4h2.08l3.61 5.12 0.85 1.2 4.8 6.8h-2.08l-3.86-5.49Z"></path></svg>
              {{else}}
              <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M7.775 3.275a.75.75 0 0 0 1.06 1.06l1.25-1.25a2 2 0 1 1 2.83 2.83l-2.5 2.5a2 2 0 0 1-2.83 0 .75.75 0 0 0-1.06 1.06 3.5 3.5 0 0 0 4.95 0l2.5-2.5a3.5 3.5 0 0 0-4.95-4.95l-1.25 1.25Zm-4.69 9.64a.75.75 0 0 0-1.06-1.06l-1.25 1.25a2 2 0 0 1-2.83-2.83l2.5-2.5a2 2 0 0 1 2.83 0 .75.75 0 0 0 1.06-1.06 3.5 3.5 0 0 0-4.95 0l-2.5 2.5a3.5 3.5 0 0 0 4.95 4.95l1.25-1.25Z"></path></svg>
              {{/if}}
              <span>{{label}}</span>
            </a>
          </p>
        {{/socialLinks}}
      {{/has}}
    </section>

    {{#has skills}}
    <section class="skills-list">
      <h2>Skills</h2>
      {{#skills}}
      <div class="skill-category">
        <strong>{{category}}:</strong>
        <div class="skill-tags-container">
          {{#items}}<span class="skill-tag">{{name}}</span>{{/items}}
        </div>
      </div>
      {{/skills}}
    </section>
    {{/has}}

    {{#has languages}}
    <section>
      <h2>Languages</h2>
      <div class="language-tags-container">
        {{#languages}}
        <span class="language-tag lang-{{lowercase language}}">{{language}} <span class="proficiency">({{proficiency}})</span></span>
        {{/languages}}
      </div>
    </section>
    {{/has}}

    {{#has interests}}
    <section>
      <h2>Interests</h2>
      <p>{{join interests ", "}}</p>
    </section>
    {{/has}}

  </aside>

  <main class="right-column">
    <section>
      <h2>Summary</h2>
      <p>Experienced full stack developer specializing in React, Node.js, and cloud architecture. Passionate about open source, developer tooling, and building products that make developers' lives easier. Speaker at 10+ conferences, maintainer of 3 popular open source projects with 15K+ combined GitHub stars.</p>
    </section>

    {{#has experience}}
    <section>
      <h2>Experience</h2>
      {{#experience}}
      <div class="experience-item">
        <h3>{{role}}</h3>
        <p><strong class="company-name">{{company}}</strong> | {{fmtDate startDate}} — {{fmtDate endDate}}</p>
        {{#description}}<p>{{description}}</p>{{/description}}
        {{#has highlights}}
        <ul>
          {{#highlights}}<li>{{.}}</li>{{/highlights}}
        </ul>
        {{/has}}
      </div>
      {{/experience}}
    </section>
    {{/has}}

    {{#has education}}
    <section>
      <h2>Education</h2>
      {{#education}}
      <div class="education-item">
        <h3>{{degree}}{{#field}} in {{field}}{{/field}}</h3>
        <p><strong>{{institution}}</strong> | {{fmtDate startDate}} — {{fmtDate endDate}}</p>
      </div>
      {{/education}}
    </section>
    {{/has}}

    {{#has projects}}
    <section>
      <h2>Projects</h2>
      {{#projects}}
      <div class="experience-item">
        <h3>{{name}}</h3>
        {{#tagline}}<p><em>{{tagline}}</em></p>{{/tagline}}
        {{#description}}<p>{{description}}</p>{{/description}}
        {{#has techStack}}
        <p><strong>Tech:</strong> {{join techStack ", "}}</p>
        {{/has}}
        <p>
          {{#liveUrl}}<a href="{{liveUrl}}">Live Demo</a>{{/liveUrl}}
          {{#if repoUrl}}{{#if liveUrl}} | {{/if}}<a href="{{repoUrl}}">Source Code</a>{{/if}}
        </p>
      </div>
      {{/projects}}
    </section>
    {{/has}}

    {{#has certifications}}
    <section>
      <h2>Certifications</h2>
      {{#certifications}}
      <div class="item">
        <h3>{{name}} — {{issuer}}</h3>
        <p>{{fmtDate date}}</p>
      </div>
      {{/certifications}}
    </section>
    {{/has}}

    {{#has publications}}
    <section>
      <h2>Publications</h2>
      {{#publications}}
      <div class="item">
        <h3>{{title}} — {{publisher}}</h3>
        <p>{{fmtDate date}}</p>
      </div>
      {{/publications}}
    </section>
    {{/has}}

    {{#has awards}}
    <section>
      <h2>Awards</h2>
      {{#awards}}
      <div class="item">
        <h3>{{title}} — {{issuer}}</h3>
        <p>{{date}}</p>
        {{#if description}}<p>{{description}}</p>{{/if}}
      </div>
      {{/awards}}
    </section>
    {{/has}}

    {{#has volunteer}}
    <section>
      <h2>Volunteer</h2>
      {{#volunteer}}
      <div class="item">
        <h3>{{role}}</h3>
        <p>{{fmtDate startDate}} – {{fmtDate endDate}}</p>
        <p><strong class="organization-name">{{organization}}</strong></p>
        {{#if description}}<p>{{description}}</p>{{/if}}
      </div>
      {{/volunteer}}
    </section>
    {{/has}}

    {{#has testimonials}}
    <section>
      <h2>Testimonials</h2>
      {{#testimonials}}
      <div class="testimonial-item">
        <blockquote>"{{quote}}"</blockquote>
        <cite>— {{author}}, {{role}} · {{company}}</cite>
      </div>
      {{/testimonials}}
    </section>
    {{/has}}

  </main>
</div>
<footer>
  <p>Built with <a href="{{toolsUrl}}">One File Tools</a></p>
</footer>
</body>
</html>