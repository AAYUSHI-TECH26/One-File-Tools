<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{displayName}} — Resume</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Courier+Prime&family=Overpass+Mono&display=swap" rel="stylesheet">
<style>
  /* === Reset === */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background-color: #000;
    background-image: repeating-linear-gradient(
        90deg, /* Straight (horizontal) stripes */
        transparent,
        transparent 25px,
        rgba(221, 221, 221, 0.05) 25px, /* #ddd color */
        rgba(221, 221, 221, 0.05) 28px, /* Thicker stripe */
        transparent 28px,
        transparent 50px,
        rgba(221, 221, 221, 0.05) 50px,
        rgba(221, 221, 221, 0.05) 54px  /* Thicker stripe */
    );
  }

  /* === Base === */
  body {
    font-family: 'Courier Prime', Courier, monospace;
    font-size: 9pt;
    line-height: 1.6;
    color: #333;
    background: #fff;
    padding: 2rem;
    max-width: 8.5in;
    margin: 2rem auto;
    border: 1px solid #ddd;
    box-shadow: 0 0 15px rgba(255,255,255,0.1);
  }

  h1, h2, h3 {
    font-family: 'Overpass Mono', monospace;
    color: #000;
    margin-bottom: 0.5em;
  }

  h1 {
    font-size: 22pt;
    letter-spacing: 1px;
    /* Replaced dashed border with a background-image for longer dashes */
    border-bottom: 2px solid transparent;
    padding-bottom: 10px;
    margin-bottom: 10px;
    background-image: linear-gradient(to right, #000 75%, transparent 25%);
    background-repeat: repeat-x;
    background-position: bottom;
    background-size: 12px 2px; /* Creates a 9px dash and a 3px gap */
    -webkit-print-color-adjust: exact; /* Ensures the line prints */
    print-color-adjust: exact;
  }

  h2 {
    font-size: 13pt;
    border-bottom: 1px solid #ccc;
    padding-bottom: 5px;
    margin-top: 1.5rem;
  }

  h3 {
    font-size: 10pt;
    font-weight: bold;
  }

  a {
    color: #000;
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }

  /* === Print === */
  @page { size: A4; margin: 15mm 20mm; }
  @media print {
    body {
        background: #fff; /* Ensure print background is white */
        border: none;
        box-shadow: none;
        margin: 0;
        max-width: 100%;
    }
  }

  /* === Layout === */
  .container {
    display: flex;
  }
  .sidebar {
    width: 33%;
    padding-right: 2rem;
  }
  .main-content {
    width: 67%;
    padding-left: 2rem;
    border-left: 1px dashed #ccc;
  }

  header {
    margin-bottom: 2rem;
  }

  .contact-info p {
    font-size: 8pt;
    color: #555;
    margin-bottom: 0.25em;
  }

  .social-links-container a {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }
  .social-link-icon {
    width: 1.1em;
    height: 1.1em;
    fill: currentColor;
    position: relative;
    top: -0.1em; /* Nudge icon up slightly */
  }


  header .title { /* Title */
    font-size: 12pt;
    font-style: italic;
    color: #222;
    margin-bottom: 0.5rem;
  }

  section {
    margin-bottom: 1.5rem;
  }

  ul {
    list-style-position: inside;
    padding-left: 1em;
  }

  li {
    margin-bottom: 0.25em;
  }

  /* === Sections === */
  .item-container {
    margin-bottom: 1.5rem;
  }

  .sidebar .item-container {
    background-color: #e1e1e1;
    padding: 1rem;
    border-radius: 4px;
    border: 1px solid #eee;
  }

  /* Two-tone card styling for main content sections */
  .main-content .structured-card {
    padding: 0;
    background-color: transparent;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid #c8c7c7;
  }
  .structured-card > h3,
  .structured-card > .project-header {
    background-color: #c8c7c7;
    padding: 0.9rem 1rem;
    margin-bottom: 0;
  }
  .structured-card-content {
    padding: 1rem;
    background-color: #e1e1e1;
  }

  .skill-item {
    margin-bottom: 0.5rem;
  }

  .item-container > p:first-of-type {
    font-weight: bold;
    color: #444;
  }

  .main-content > section:first-child h2 {
    margin-top: 0;
  }

  .skill-item {
    display: flex;
  }
  .skill-item strong {
    width: 120px;
    flex-shrink: 0;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .project-header h3 { margin-bottom: 0; }
  .project-links {
    font-size: 8pt;
    white-space: nowrap;
    flex-shrink: 0;
  }

  footer {
    text-align: center;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
    font-size: 7pt;
    color: #888;
  }
</style>
</head>
<body>

<div class="container">
  <div class="sidebar">
    <!-- Header -->
    <header>
      <h1>{{displayName}}</h1>
      {{#title}}<p class="title">{{title}}</p>{{/title}}
      <div class="contact-info">
        {{#email}}<p><a href="mailto:{{email}}">{{email}}</a></p>{{/email}}
        {{#phone}}<p>{{phone}}</p>{{/phone}}
        {{#website}}<p><a href="{{website}}">{{stripProtocol website}}</a></p>{{/website}}
        {{#locationStr}}<p>{{locationStr}}</p>{{/locationStr}}
        {{#has socialLinks}}
        <p class="social-links-container">
          {{#socialLinks}}<a href="{{url}}">
            {{#if (eq label "GitHub")}}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="social-link-icon"><path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21-.15.46-.55.38A8.013 8.013 0 0 1 8 0Z"></path></svg>{{/if}}
            {{#if (eq label "LinkedIn")}}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="social-link-icon"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2ZM8 19H5V8h3v11ZM6.5 6.73c-.97 0-1.75-.79-1.75-1.76s.78-1.76 1.75-1.76 1.75.79 1.75 1.76-.78 1.76-1.75 1.76ZM19 19h-3v-5.34c0-1.27-.03-2.9-1.76-2.9-1.76 0-2.04 1.37-2.04 2.8v5.44H9V8h2.88v1.32h.04c.42-.79 1.44-1.62 2.84-1.62 3.03 0 3.59 1.99 3.59 4.58V19Z"></path></svg>{{/if}}
            {{#if (eq label "Twitter")}}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="social-link-icon"><path d="M9.237 6.522 14.634 0H13.21l-4.573 5.46-3.65-5.46H0l5.683 8.4-5.683 7.6h1.424l4.92-5.873 3.88 5.873h4.92L9.237 6.522Zm-1.12 1.26L7.26 6.66l-4.55-6.4h2.08l3.61 5.12 0.85 1.2 4.8 6.8h-2.08l-3.86-5.49Z"></path></svg>{{/if}}
            {{#if (eq label "Blog")}}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="social-link-icon"><path d="M7.775 3.275a.75.75 0 0 0 1.06 1.06l1.25-1.25a2 2 0 1 1 2.83 2.83l-2.5 2.5a2 2 0 0 1-2.83 0 .75.75 0 0 0-1.06 1.06 3.5 3.5 0 0 0 4.95 0l2.5-2.5a3.5 3.5 0 0 0-4.95-4.95l-1.25 1.25Zm-4.69 9.64a.75.75 0 0 0-1.06-1.06l-1.25 1.25a2 2 0 0 1-2.83-2.83l2.5-2.5a2 2 0 0 1 2.83 0 .75.75 0 0 0 1.06-1.06 3.5 3.5 0 0 0-4.95 0l-2.5 2.5a3.5 3.5 0 0 0 4.95 4.95l1.25-1.25Z"></path></svg>{{/if}}
            {{label}}</a>{{^@last}} | {{/@last}}{{/socialLinks}}
        </p>
        {{/has}}
      </div>
    </header>

    <!-- Education -->
    {{#has education}}
    <section>
      <h2>✦︎ Education</h2>
      {{#education}}
      <div class="item-container">
        <h3>{{degree}}{{#field}} in {{field}}{{/field}}</h3>
        <p>{{institution}} | {{fmtDate startDate}} — {{fmtDate endDate}}</p>
      </div>
      {{/education}}
    </section>
    {{/has}}

    <!-- Languages -->
    {{#has languages}}
    <section>
      <h2>✦︎ Languages</h2>
      {{#languages}}
        <div class="item-container" style="padding: 0.75rem; margin-bottom: 0.75rem;">
          <p><strong>{{language}}:</strong> {{proficiency}}</p>
        </div>
      {{/languages}}
    </section>
    {{/has}}

    <!-- Interests -->
    {{#has interests}}
    <section>
      <h2>✦︎ Interests</h2>
      <div class="item-container">
        <p>{{join interests ", "}}</p>
      </div>
    </section>
    {{/has}}
  </div>

  <div class="main-content">
    <!-- Summary -->
    {{#if summary}}
    <section>
      <h2>✦︎ Summary</h2>
      <p>{{summary}}</p>
    </section>
    {{/if}}

    <!-- Experience -->
    {{#has experience}}
    <section>
      <h2>✦︎ Experience</h2>
      {{#experience}}
      <div class="item-container structured-card">
        <h3>{{role}}</h3>
        <div class="structured-card-content">
          <p>{{company}} | {{fmtDate startDate}} — {{fmtDate endDate}}</p>
          {{#description}}<p>{{description}}</p>{{/description}}
          {{#has highlights}}
          <ul>
            {{#highlights}}<li>{{.}}</li>{{/highlights}}
          </ul>
          {{/has}}
        </div>
      </div>
      {{/experience}}
    </section>
    {{/has}}

    <!-- Projects -->
    {{#has projects}}
    <section>
      <h2>✦︎ Projects</h2>
      {{#projects}}
      <div class="item-container structured-card">
        <div class="project-header">
          <h3>{{name}}</h3>
          <div class="project-links">
            {{#if repoUrl}}<a href="{{repoUrl}}">Repo</a>{{/if}}
            {{#if liveUrl}}{{#if repoUrl}} | {{/if}}<a href="{{liveUrl}}">Live</a>{{/if}}
          </div>
        </div>
        <div class="structured-card-content">
          {{#if techStack}}
          <p><strong>Tech:</strong> {{join techStack ", "}}</p>
          {{/if}}
          {{#description}}<p>{{description}}</p>{{/description}}
          {{#has highlights}}
          <ul>
            {{#highlights}}<li>{{.}}</li>{{/highlights}}
          </ul>
          {{/has}}
        </div>
      </div>
      {{/projects}}
    </section>
    {{/has}}

    <!-- Skills -->
    {{#has skills}}
    <section>
      <h2>✦︎ Skills</h2>
      {{#skills}}
      <div class="skill-item">
        <strong>{{category}}:</strong>
        <span>{{#items}}{{name}}{{^@last}}, {{/@last}}{{/items}}</span>
      </div>
      {{/skills}}
    </section>
    {{/has}}

    <!-- Certifications -->
    {{#has certifications}}
    <section>
      <h2>✦︎ Certifications</h2>
      {{#certifications}}
      <div class="item-container structured-card">
        <h3>{{name}}</h3>
        <div class="structured-card-content">
          <p>{{issuer}} | {{date}}</p>
        </div>
      </div>
      {{/certifications}}
    </section>
    {{/has}}

    <!-- Publications -->
    {{#has publications}}
    <section>
      <h2>✦︎ Publications</h2>
      {{#publications}}
      <div class="item-container structured-card">
        <h3><a href="{{url}}">{{title}}</a></h3>
        <div class="structured-card-content">
          <p>{{publisher}} | {{date}}</p>
        </div>
      </div>
      {{/publications}}
    </section>
    {{/has}}

    <!-- Talks -->
    {{#has talks}}
    <section>
      <h2>✦︎ Talks</h2>
      {{#talks}}
      <div class="item-container structured-card">
        <h3>{{title}}</h3>
        <div class="structured-card-content">
          <p>{{event}} | {{date}} | {{location}}</p>
          <p>
              {{#if slidesUrl}}<a href="{{slidesUrl}}">Slides</a>{{/if}}
              {{#if videoUrl}}{{#if slidesUrl}} | {{/if}}<a href="{{videoUrl}}">Video</a>{{/if}}
          </p>
        </div>
      </div>
      {{/talks}}
    </section>
    {{/has}}

    <!-- Awards -->
    {{#has awards}}
    <section>
      <h2>✦︎ Awards</h2>
      {{#awards}}
      <div class="item-container structured-card">
        <h3>{{title}}</h3>
        <div class="structured-card-content">
          <p>{{issuer}} | {{date}}</p>
          {{#if description}}<p>{{description}}</p>{{/if}}
        </div>
      </div>
      {{/awards}}
    </section>
    {{/has}}

    <!-- Volunteer -->
    {{#has volunteer}}
    <section>
      <h2>✦︎ Volunteer</h2>
      {{#volunteer}}
      <div class="item-container structured-card">
        <h3>{{role}} at {{organization}}</h3>
        <div class="structured-card-content">
          <p>{{fmtDate startDate}} — {{fmtDate endDate}}</p>
          {{#if description}}<p>{{description}}</p>{{/if}}
        </div>
      </div>
      {{/volunteer}}
    </section>
    {{/has}}

    <!-- Testimonials -->
    {{#has testimonials}}
    <section>
      <h2>✦︎ Testimonials</h2>
      {{#testimonials}}
      <div class="item-container">
        <blockquote style="border-left: 2px solid #ccc; padding-left: 1em; font-style: italic; margin: 0.5em 0;"><p>"{{quote}}"</p></blockquote>
        <p style="text-align: right;"><em>— {{author}}, {{role}} at {{company}}</em></p>
      </div>
      {{/testimonials}}
    </section>
    {{/has}}
  </div>
</div>

<footer>
  <p>Built with <a href="{{toolsUrl}}">One File Tools</a></p>
</footer>

</body>
</html>